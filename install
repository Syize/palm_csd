# project install script
#--------------------------------------------------------------------------------#
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
   DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
   SOURCE="$(readlink "$SOURCE")"
   [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE" # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
SCRIPT_LOCATION="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

project_root_dir=$(readlink -f "${SCRIPT_LOCATION}/")
project_build_dir=$(readlink -f "${project_root_dir}/build/")
project_share_dir=$(readlink -f "${project_root_dir}/share/")
project_src_dir=$(readlink -f "${project_root_dir}/src/")

install_prefix="${project_build_dir}"

program_name="palm_csd"

install_function() {
   printf "### %s\n" "Installing ${program_name} ..."
   install_bin_dir="${install_prefix}/bin"
   venv_dir="${install_prefix}/.palm_csd_venv"
   project_palmcsd="${project_root_dir}/palm_csd.py"
   install_palmcsd="${install_bin_dir}/palm_csd"
   project_stats="${project_root_dir}/static_driver_stats.py"
   install_stats="${install_bin_dir}/static_driver_stats"
   if [ "${do_clean}" == "true" ]; then
      rm -f "${install_palmcsd}"
      rm -f "${install_stats}"
      rm -rf "${venv_dir}"
   fi
   mkdir -p "${install_bin_dir}"
   chmod a+x $(realpath "${project_palmcsd}")
   chmod a+x $(realpath "${project_stats}")
   if [ "${venv}" == "true" ]; then

      # check if pip and the venv module is available
      pip="false"
      if [ -x "$(command -v pip)" ]; then
         python3 << EOF
import venv
EOF
         if [ $? -eq 0 ]; then pip="true"; fi
      fi

      if [ "${pip}" == "true" ]; then
         # venv and pip virtual environment
         if [ ! -d "${venv_dir}" ]; then
            echo "Creating venv virtual environment"
            python3 -m venv "${venv_dir}"
            if [ $? -ne 0 ]; then 
               echo "Failed to create venv virtual environment" "${venv_dir}"
               echo "Exiting ..."
               exit 1 
            fi
            echo "Created virtual environment" "${venv_dir}"
         else
            echo "Using venv virtual environment" "${venv_dir}"
         fi
         source "${venv_dir}/bin/activate"
         if [ $? -ne 0 ]; then 
            echo "Failed to activate venv virtual environment" "${venv_dir}"
            echo "Exiting ..."
            exit 1 
            fi
         pip install --upgrade pip
         pip install -r "${project_root_dir}/requirements.txt"
         deactivate
         cat << EOF > "${install_palmcsd}"
#!/usr/bin/env bash
# unset external proj variables that might interfere with the proj version installed in the venv
unset PROJ_LIB
unset PROJ_DATA
# activate venv
source "${venv_dir}/bin/activate"
# get the name of the calling bash script
script_name=\$(basename "\$0")
# run palm_csd, ensure that sys.argv[0] is set to the script name
python3 -c "
import sys
sys.argv[0] = '\${script_name}'
sys.path = [p for p in sys.path if p != ''] # remove current directory from module path
sys.path.insert(0, '${project_root_dir}')   # insert project root directory
exec(open('${project_palmcsd}').read())
" "\$@"
# deactivate venv
deactivate
EOF
         chmod a+x "${install_palmcsd}"
         cat << EOF > "${install_stats}"
#!/usr/bin/env bash
# activate venv
source "${venv_dir}/bin/activate"
# get the name of the calling bash script
script_name=\$(basename "\$0")
# run static driver statistics tool, ensure that sys.argv[0] is set to the script name
python3 -c "
import sys
sys.argv[0] = '\${script_name}'
sys.path = [p for p in sys.path if p != ''] # remove current directory from module path
sys.path.insert(0, '${project_root_dir}')   # insert project root directory
exec(open('${project_stats}').read())
" "\$@"
# deactivate venv
deactivate
EOF
         chmod a+x "${install_stats}"
      else
         echo "pip is not available. Please install it."
         exit 1
      fi
   else
      ln -s -f $(realpath --relative-to="${install_bin_dir}" "${project_palmcsd}") "${install_palmcsd}"
      ln -s -f $(realpath --relative-to="${install_bin_dir}" "${project_stats}") "${install_stats}"
   fi
   printf "### %s\n" "Installing ${program_name} finished."
}

show_usage() {
   echo "Usage: $0 [-h] [-e] [-p <install_prefix>] [-x]"
}

show_help() {
   show_usage
   echo "      -h                     show this help message"
   echo "      -e                     use a virtual environment and install dependencies"
   echo "      -p <install_prefix>    set installation directory"
   echo "      -x                     clean already existing build files"
}

venv="false"
while getopts ":p:ehx" o; do
   case "${o}" in
      p)
         install_prefix="$(readlink -m "${OPTARG}")"
         ;;
      e)
         venv="true"
         ;;
      x)
         do_clean="true"
         ;;
      h)
         show_help
         exit 0
         ;;
      *)
         show_usage
         exit 1
         ;;
   esac
done
# strip all parsed options from the options list
shift $((OPTIND-1))

install_function
